<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>New Post — PostBoard</title>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700;900&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
    <style>
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

        :root {
            --bg:      #0d0d0f;
            --card:    #1a1a20;
            --border:  rgba(255,255,255,0.07);
            --accent:  #e8c46a;
            --accent2: #f0856a;
            --text:    #eeeef0;
            --muted:   #6b6b78;
            --radius:  14px;
        }

        html { scroll-behavior: smooth; }

        body {
            font-family: 'DM Sans', sans-serif;
            background: var(--bg);
            color: var(--text);
            min-height: 100vh;
            overflow-x: hidden;
        }

        /* Noise */
        body::before {
            content: '';
            position: fixed;
            inset: 0;
            background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.75' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.04'/%3E%3C/svg%3E");
            pointer-events: none;
            z-index: 0;
            opacity: 0.5;
        }

        /* Glows */
        .glow {
            position: fixed;
            width: 500px; height: 500px;
            border-radius: 50%;
            filter: blur(120px);
            pointer-events: none;
            z-index: 0;
        }
        .glow-1 { background: rgba(232,196,106,0.07); top: -160px; right: -140px; }
        .glow-2 { background: rgba(240,133,106,0.05); bottom: -180px; left: -160px; }

        /* ── Header ── */
        header {
            position: sticky; top: 0; z-index: 100;
            background: rgba(13,13,15,0.85);
            backdrop-filter: blur(18px);
            -webkit-backdrop-filter: blur(18px);
            border-bottom: 1px solid var(--border);
            padding: 0 clamp(1.5rem, 5vw, 4rem);
            height: 68px;
            display: flex; align-items: center; justify-content: space-between;
        }

        .logo {
            font-family: 'Playfair Display', serif;
            font-size: 1.5rem; font-weight: 900;
            letter-spacing: -0.02em;
            background: linear-gradient(135deg, var(--accent), var(--accent2));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            text-decoration: none;
        }
        .logo span { font-style: italic; }

        .back-btn {
            display: inline-flex; align-items: center; gap: 0.4rem;
            color: var(--muted); font-size: 0.82rem;
            text-decoration: none;
            transition: color 0.17s ease;
        }
        .back-btn:hover { color: var(--text); }
        .back-btn svg { width: 15px; height: 15px; }

        /* ── Main ── */
        main {
            position: relative; z-index: 1;
            max-width: 680px; margin: 0 auto;
            padding: clamp(2.5rem, 6vw, 5rem) clamp(1.2rem, 4vw, 2rem) 6rem;
            animation: slideUp 0.4s ease both;
        }

        @keyframes slideUp {
            from { opacity: 0; transform: translateY(20px); }
            to   { opacity: 1; transform: translateY(0); }
        }

        .page-label {
            font-size: 0.72rem; font-weight: 500;
            letter-spacing: 0.14em; text-transform: uppercase;
            color: var(--accent); margin-bottom: 0.6rem;
        }

        h1 {
            font-family: 'Playfair Display', serif;
            font-size: clamp(2rem, 5vw, 2.8rem);
            font-weight: 900; letter-spacing: -0.03em; line-height: 1.05;
        }
        h1 em { font-style: italic; color: var(--accent); }

        .divider {
            width: 48px; height: 3px;
            background: linear-gradient(90deg, var(--accent), var(--accent2));
            border-radius: 2px;
            margin: 1.4rem 0 2rem;
        }

        /* ── Form card ── */
        .form-card {
            background: var(--card);
            border: 1px solid var(--border);
            border-radius: var(--radius);
            overflow: hidden;
            transition: border-color 0.22s ease, box-shadow 0.22s ease;
        }
        .form-card:focus-within {
            border-color: rgba(232,196,106,0.28);
            box-shadow: 0 0 0 3px rgba(232,196,106,0.06);
        }

        /* ── Username field ── */
        .field {
            padding: 1.4rem 1.8rem;
            position: relative;
        }

        .field + .field {
            border-top: 1px solid var(--border);
        }

        .field-label {
            display: block;
            font-size: 0.72rem; font-weight: 500;
            letter-spacing: 0.1em; text-transform: uppercase;
            color: var(--muted); margin-bottom: 0.6rem;
        }

        .input-wrap {
            display: flex; align-items: center; gap: 0.6rem;
        }

        .at-sign {
            font-size: 1.1rem; font-weight: 500;
            color: var(--accent); flex-shrink: 0;
            line-height: 1;
        }

        input[type="text"] {
            flex: 1; background: transparent; border: none; outline: none;
            color: var(--text);
            font-family: 'DM Sans', sans-serif;
            font-size: 1rem; font-weight: 400;
            caret-color: var(--accent);
        }
        input[type="text"]::placeholder { color: var(--muted); }

        /* live avatar preview */
        .avatar-preview {
            width: 34px; height: 34px;
            border-radius: 50%;
            background: linear-gradient(135deg, var(--accent), var(--accent2));
            display: grid; place-items: center;
            font-size: 0.8rem; font-weight: 700;
            color: #0d0d0f; flex-shrink: 0;
            opacity: 0;
            transform: scale(0.7);
            transition: opacity 0.2s ease, transform 0.2s ease;
        }
        .avatar-preview.visible {
            opacity: 1; transform: scale(1);
        }

        /* ── Textarea field ── */
        textarea {
            width: 100%; min-height: 200px;
            background: transparent; border: none; outline: none;
            color: var(--text);
            font-family: 'DM Sans', sans-serif;
            font-size: 1rem; font-weight: 400; line-height: 1.7;
            resize: vertical;
            caret-color: var(--accent);
        }
        textarea::placeholder { color: var(--muted); }

        .char-count {
            text-align: right;
            font-size: 0.72rem; color: var(--muted);
            margin-top: 0.5rem;
            transition: color 0.2s ease;
        }
        .char-count.warn { color: var(--accent2); }

        /* ── Tips strip ── */
        .tips {
            display: flex; align-items: flex-start; gap: 0.6rem;
            background: rgba(232,196,106,0.05);
            border: 1px solid rgba(232,196,106,0.12);
            border-radius: var(--radius);
            padding: 0.9rem 1.1rem;
            margin: 1.4rem 0 0;
            font-size: 0.78rem; color: var(--muted); line-height: 1.5;
        }
        .tips svg { width: 14px; height: 14px; color: var(--accent); flex-shrink: 0; margin-top: 1px; }

        /* ── Actions ── */
        .form-actions {
            display: flex; align-items: center;
            gap: 0.8rem; margin-top: 1.6rem;
            flex-wrap: wrap;
        }

        .btn {
            display: inline-flex; align-items: center; gap: 0.4rem;
            padding: 0.6rem 1.3rem;
            border-radius: 999px;
            font-family: 'DM Sans', sans-serif;
            font-size: 0.85rem; font-weight: 500;
            cursor: pointer; text-decoration: none;
            transition: all 0.18s ease;
            border: 1px solid transparent;
        }
        .btn svg { width: 14px; height: 14px; flex-shrink: 0; }

        .btn-submit {
            background: var(--accent); color: #0d0d0f;
            opacity: 0.45;
            pointer-events: none;
            transition: opacity 0.2s ease, transform 0.18s ease, box-shadow 0.18s ease, background 0.18s ease;
        }
        .btn-submit.ready {
            opacity: 1; pointer-events: auto;
        }
        .btn-submit.ready:hover {
            background: #f0d080;
            transform: translateY(-2px);
            box-shadow: 0 6px 24px rgba(232,196,106,0.3);
        }
        .btn-submit.ready:active { transform: translateY(0); }

        .btn-cancel {
            background: rgba(255,255,255,0.04);
            color: var(--muted); border-color: var(--border);
        }
        .btn-cancel:hover {
            background: rgba(255,255,255,0.08);
            color: var(--text); border-color: rgba(255,255,255,0.14);
        }

        @media (max-width: 540px) {
            .field { padding: 1.1rem 1.2rem; }
            .form-actions { flex-direction: column; align-items: stretch; }
            .btn { justify-content: center; }
        }
    </style>
</head>
<body>

    <div class="glow glow-1"></div>
    <div class="glow glow-2"></div>

    <!-- Header -->
    <header>
        <a href="http://localhost:8080/posts" class="logo">Post<span>Board</span></a>
        <a href="http://localhost:8080/posts" class="back-btn">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <polyline points="15 18 9 12 15 6"/>
            </svg>
            Back to Posts
        </a>
    </header>

    <!-- Main -->
    <main>
        <p class="page-label">New Post</p>
        <h1>Share something <em>new</em></h1>
        <div class="divider"></div>

        <form method="post" action="/posts" id="postForm">
            <div class="form-card">

                <!-- Username -->
                <div class="field">
                    <label class="field-label" for="username">Your Username</label>
                    <div class="input-wrap">
                        <span class="at-sign">@</span>
                        <input
                            type="text"
                            id="username"
                            name="username"
                            placeholder="enter username"
                            autocomplete="off"
                            maxlength="30"
                        >
                        <div class="avatar-preview" id="avatarPreview"></div>
                    </div>
                </div>

                <!-- Content -->
                <div class="field">
                    <label class="field-label" for="content">Your Post</label>
                    <textarea
                        id="content"
                        name="content"
                        rows="9"
                        maxlength="1000"
                        placeholder="What's on your mind?"
                    ></textarea>
                    <div class="char-count" id="charCount">0 / 1000</div>
                </div>

            </div>

            <!-- Tip -->
            <div class="tips">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/>
                </svg>
                Fill in both your username and post content to publish. Both fields are required.
            </div>

            <div class="form-actions">
                <button type="submit" class="btn btn-submit" id="submitBtn">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2">
                        <line x1="22" y1="2" x2="11" y2="13"/>
                        <polygon points="22 2 15 22 11 13 2 9 22 2"/>
                    </svg>
                    Publish Post
                </button>
                <a href="http://localhost:8080/posts" class="btn btn-cancel">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <line x1="18" y1="6" x2="6" y2="18"/>
                        <line x1="6" y1="6" x2="18" y2="18"/>
                    </svg>
                    Cancel
                </a>
            </div>
        </form>
    </main>

    <script>
        const usernameInput = document.getElementById('username');
        const contentInput  = document.getElementById('content');
        const submitBtn     = document.getElementById('submitBtn');
        const avatarEl      = document.getElementById('avatarPreview');
        const charCount     = document.getElementById('charCount');

        // Avatar preview
        usernameInput.addEventListener('input', () => {
            const val = usernameInput.value.trim();
            if (val.length > 0) {
                avatarEl.textContent = val.charAt(0).toUpperCase();
                avatarEl.classList.add('visible');
            } else {
                avatarEl.classList.remove('visible');
            }
            checkReady();
        });

        // Char counter + auto-resize
        contentInput.addEventListener('input', () => {
            const len = contentInput.value.length;
            charCount.textContent = `${len} / 1000`;
            charCount.classList.toggle('warn', len > 850);
            contentInput.style.height = 'auto';
            contentInput.style.height = contentInput.scrollHeight + 'px';
            checkReady();
        });

        // Enable submit only when both fields filled
        function checkReady() {
            const ok = usernameInput.value.trim().length > 0
                    && contentInput.value.trim().length > 0;
            submitBtn.classList.toggle('ready', ok);
        }

        checkReady();
    </script>
</body>
</html>







