<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Post Detail — PostBoard</title>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700;900&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
    <style>
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

        :root {
            --bg:      #0d0d0f;
            --card:    #1a1a20;
            --border:  rgba(255,255,255,0.07);
            --accent:  #e8c46a;
            --accent2: #f0856a;
            --text:    #eeeef0;
            --muted:   #6b6b78;
            --danger:  #e05c5c;
            --radius:  14px;
        }

        html { scroll-behavior: smooth; }

        body {
            font-family: 'DM Sans', sans-serif;
            background: var(--bg);
            color: var(--text);
            min-height: 100vh;
            overflow-x: hidden;
        }

        /* Noise */
        body::before {
            content: '';
            position: fixed; inset: 0;
            background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.75' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.04'/%3E%3C/svg%3E");
            pointer-events: none; z-index: 0; opacity: 0.5;
        }

        /* Glows */
        .glow {
            position: fixed; width: 500px; height: 500px;
            border-radius: 50%; filter: blur(120px);
            pointer-events: none; z-index: 0;
        }
        .glow-1 { background: rgba(232,196,106,0.07); top: -160px; right: -140px; }
        .glow-2 { background: rgba(240,133,106,0.05); bottom: -180px; left: -160px; }

        /* ── Header ── */
        header {
            position: sticky; top: 0; z-index: 100;
            background: rgba(13,13,15,0.85);
            backdrop-filter: blur(18px);
            -webkit-backdrop-filter: blur(18px);
            border-bottom: 1px solid var(--border);
            padding: 0 clamp(1.5rem, 5vw, 4rem);
            height: 68px;
            display: flex; align-items: center; justify-content: space-between;
        }

        .logo {
            font-family: 'Playfair Display', serif;
            font-size: 1.5rem; font-weight: 900;
            letter-spacing: -0.02em;
            background: linear-gradient(135deg, var(--accent), var(--accent2));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            text-decoration: none;
        }
        .logo span { font-style: italic; }

        .back-btn {
            display: inline-flex; align-items: center; gap: 0.4rem;
            color: var(--muted); font-size: 0.82rem;
            text-decoration: none;
            transition: color 0.17s ease;
        }
        .back-btn:hover { color: var(--text); }
        .back-btn svg { width: 15px; height: 15px; }

        /* ── Main ── */
        main {
            position: relative; z-index: 1;
            max-width: 680px; margin: 0 auto;
            padding: clamp(2.5rem, 6vw, 5rem) clamp(1.2rem, 4vw, 2rem) 6rem;
        }

        /* ── Breadcrumb ── */
        .breadcrumb {
            display: flex; align-items: center; gap: 0.45rem;
            font-size: 0.75rem; color: var(--muted);
            margin-bottom: 2rem;
            animation: slideUp 0.3s ease both;
        }
        .breadcrumb a {
            color: var(--muted); text-decoration: none;
            transition: color 0.15s ease;
        }
        .breadcrumb a:hover { color: var(--accent); }
        .breadcrumb svg { width: 12px; height: 12px; opacity: 0.5; }
        .breadcrumb span { color: var(--text); }

        /* ── Author row ── */
        .author-row {
            display: flex; align-items: center; gap: 1rem;
            margin-bottom: 1.8rem;
            animation: slideUp 0.35s ease both;
            animation-delay: 0.05s;
        }

        .avatar {
            width: 52px; height: 52px;
            border-radius: 50%;
            background: linear-gradient(135deg, var(--accent), var(--accent2));
            display: grid; place-items: center;
            font-size: 1.1rem; font-weight: 700;
            color: #0d0d0f; flex-shrink: 0;
            box-shadow: 0 0 0 3px rgba(232,196,106,0.15);
        }

        .author-info {}
        .author-name {
            font-size: 1rem; font-weight: 500;
            color: var(--accent);
        }
        .post-id {
            font-size: 0.72rem; color: var(--muted);
            margin-top: 0.15rem;
            letter-spacing: 0.04em;
        }

        /* ── Content card ── */
        .content-card {
            background: var(--card);
            border: 1px solid var(--border);
            border-radius: var(--radius);
            padding: 2rem 2.2rem;
            position: relative;
            overflow: hidden;
            animation: slideUp 0.4s ease both;
            animation-delay: 0.1s;
        }

        /* accent left bar */
        .content-card::before {
            content: '';
            position: absolute; top: 0; left: 0;
            width: 3px; height: 100%;
            background: linear-gradient(180deg, var(--accent), var(--accent2));
        }

        /* large quote mark */
        .content-card::after {
            content: '\201C';
            position: absolute;
            top: -0.6rem; right: 1.4rem;
            font-family: 'Playfair Display', serif;
            font-size: 8rem; font-weight: 900;
            color: rgba(232,196,106,0.06);
            line-height: 1;
            pointer-events: none;
            user-select: none;
        }

        .post-content {
            font-size: 1.15rem;
            font-weight: 400;
            line-height: 1.75;
            color: var(--text);
            position: relative;
            z-index: 1;
            white-space: pre-wrap;
            word-break: break-word;
        }

        /* ── Divider ── */
        .section-divider {
            height: 1px;
            background: var(--border);
            margin: 2rem 0;
            animation: slideUp 0.4s ease both;
            animation-delay: 0.15s;
        }

        /* ── Actions ── */
        .actions {
            display: flex; align-items: center;
            gap: 0.7rem; flex-wrap: wrap;
            animation: slideUp 0.4s ease both;
            animation-delay: 0.2s;
        }

        .actions-label {
            font-size: 0.72rem; font-weight: 500;
            letter-spacing: 0.1em; text-transform: uppercase;
            color: var(--muted);
            margin-right: 0.3rem;
        }

        .btn {
            display: inline-flex; align-items: center; gap: 0.4rem;
            padding: 0.55rem 1.1rem;
            border-radius: 999px;
            font-family: 'DM Sans', sans-serif;
            font-size: 0.82rem; font-weight: 500;
            cursor: pointer; text-decoration: none;
            transition: all 0.18s ease;
            border: 1px solid transparent;
        }
        .btn svg { width: 13px; height: 13px; flex-shrink: 0; }

        .btn-edit {
            background: rgba(232,196,106,0.10);
            color: var(--accent);
            border-color: rgba(232,196,106,0.2);
        }
        .btn-edit:hover {
            background: rgba(232,196,106,0.2);
            border-color: rgba(232,196,106,0.38);
            transform: translateY(-1px);
        }

        .btn-delete {
            background: rgba(224,92,92,0.08);
            color: var(--danger);
            border-color: rgba(224,92,92,0.18);
        }
        .btn-delete:hover {
            background: rgba(224,92,92,0.18);
            border-color: rgba(224,92,92,0.35);
            transform: translateY(-1px);
        }

        .delete-form { display: inline; }
        .delete-form button { font-family: inherit; cursor: pointer; }

        /* ── Keyframes ── */
        @keyframes slideUp {
            from { opacity: 0; transform: translateY(18px); }
            to   { opacity: 1; transform: translateY(0); }
        }

        /* ── Responsive ── */
        @media (max-width: 540px) {
            .content-card { padding: 1.4rem 1.3rem; }
            .post-content { font-size: 1rem; }
            .actions { flex-direction: column; align-items: flex-start; }
            .btn { width: 100%; justify-content: center; }
        }
    </style>
</head>
<body>

    <div class="glow glow-1"></div>
    <div class="glow glow-2"></div>

    <!-- Header -->
    <header>
        <a href="http://localhost:8080/posts" class="logo">Post<span>Board</span></a>
        <a href="http://localhost:8080/posts" class="back-btn">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <polyline points="15 18 9 12 15 6"/>
            </svg>
            Back to Posts
        </a>
    </header>

    <!-- Main -->
    <main>

        <!-- Breadcrumb -->
        <nav class="breadcrumb">
            <a href="http://localhost:8080/posts">Posts</a>
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <polyline points="9 18 15 12 9 6"/>
            </svg>
            <span>@<%= post.username %></span>
        </nav>

        <!-- Author -->
        <div class="author-row">
            <div class="avatar" id="avatarEl"></div>
            <div class="author-info">
                <div class="author-name">@<%= post.username %></div>
                <div class="post-id">Post ID: <%= post.id %></div>
            </div>
        </div>

        <!-- Content -->
        <div class="content-card">
            <p class="post-content"><%= post.content %></p>
        </div>

        <div class="section-divider"></div>

        <!-- Actions -->
        <div class="actions">
            <span class="actions-label">Actions</span>

            <a href="http://localhost:8080/posts/<%= post.id %>/edit" class="btn btn-edit">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/>
                    <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/>
                </svg>
                Edit Post
            </a>

            <form class="delete-form" method="post" action="/posts/<%= post.id %>?_method=DELETE">
                <button type="submit" class="btn btn-delete">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <polyline points="3 6 5 6 21 6"/>
                        <path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/>
                        <path d="M10 11v6"/><path d="M14 11v6"/>
                        <path d="M9 6V4h6v2"/>
                    </svg>
                    Delete Post
                </button>
            </form>
        </div>

    </main>

    <script>
        // Avatar initial
        const username = '<%= post.username %>';
        document.getElementById('avatarEl').textContent = username.charAt(0).toUpperCase();

        // Delete confirmation
        document.querySelector('.delete-form').addEventListener('submit', function(e) {
            if (!confirm('Delete this post permanently?')) e.preventDefault();
        });
    </script>
</body>
</html>







